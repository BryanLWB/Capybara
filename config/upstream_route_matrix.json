    },
    {
      "app_route": "GET /api/app/v1/public/config",
      "upstream_route": "GET /api/v1/guest/comm/config"
    },
    {
      "app_route": "GET /api/app/v1/catalog/plans",
      "upstream_route": "GET /api/v1/guest/plan/fetch or GET /api/v1/user/plan/fetch"
    },
    {
      "app_route": "GET /api/app/v1/account/profile",
      "upstream_route": "GET /api/v1/user/info"
