    },
    {
      "app_route": "POST /api/app/v1/referrals/withdrawals",
      "upstream_route": "POST /api/v1/user/ticket/withdraw"
    },
    {
      "app_route": "POST /api/app/v1/rewards/redeem",
      "upstream_route": "POST /api/v1/user/gift-card/redeem"
    },
    {
      "app_route": "GET /api/app/v1/client/config",
      "upstream_route": "GET /api/v1/client/app/getConfig?token=..."
    },
    {
      "app_route": "GET /api/app/v1/client/version",
      "upstream_route": "GET /api/v1/client/app/getVersion?token=..."
    },
    {
      "app_route": "GET /api/app/v1/client/downloads",
      "upstream_route": "GET /api/v1/client/app/getVersion?token=..."
    }
