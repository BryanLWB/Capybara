    },
    {
      "app_route": "POST /api/app/v1/commerce/orders/{order_ref}/checkout",
      "upstream_route": "POST /api/v1/user/order/checkout"
    },
    {
      "app_route": "GET /api/app/v1/commerce/orders/{order_ref}/status",
      "upstream_route": "GET /api/v1/user/order/check"
    },
    {
      "app_route": "POST /api/app/v1/commerce/orders/{order_ref}/cancel",
      "upstream_route": "POST /api/v1/user/order/cancel"
    },
    {
      "app_route": "GET /api/app/v1/referrals/overview",
      "upstream_route": "GET /api/v1/user/invite/fetch"
    },
    {
      "app_route": "GET /api/app/v1/referrals/records",
      "upstream_route": "GET /api/v1/user/invite/details"
    },
    {
      "app_route": "POST /api/app/v1/referrals/codes",
