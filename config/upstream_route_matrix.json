    },
    {
      "app_route": "POST /api/app/v1/commerce/coupons/validate",
      "upstream_route": "POST /api/v1/user/coupon/check"
    },
    {
      "app_route": "GET /api/app/v1/commerce/orders",
      "upstream_route": "GET /api/v1/user/order/fetch"
    },
    {
      "app_route": "POST /api/app/v1/commerce/orders",
